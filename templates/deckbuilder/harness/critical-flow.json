{
  "version": "1.0.0",
  "name": "deckbuilder-early-run",
  "timeoutMs": 2500,
  "milestoneScenes": [
    {
      "sceneId": "MainMenuScene",
      "scene": "TitleScene",
      "label": "Main Menu",
      "primaryAction": "Start New Run",
      "acceptanceCriteria": [
        {
          "id": "renders-visibly",
          "description": "The main menu renders visibly with the title menu on-screen.",
          "stepIds": ["title"]
        },
        {
          "id": "primary-action-visible",
          "description": "The Start New Run action is visible on the main menu.",
          "controlIds": ["start-new-run"]
        },
        {
          "id": "progression-possible",
          "description": "The Start New Run action can advance the run into character select.",
          "actionIds": ["start-new-run"],
          "stepIds": ["start-new-run", "character-select"]
        },
        {
          "id": "no-runtime-blocker",
          "description": "No runtime blocker prevents the main menu from loading or starting a run.",
          "stepIds": ["title", "start-new-run"]
        }
      ]
    },
    {
      "sceneId": "CharacterSelectScene",
      "scene": "CharacterSelectScene",
      "label": "Character Select",
      "primaryAction": "Confirm Selection",
      "acceptanceCriteria": [
        {
          "id": "renders-visibly",
          "description": "The character select screen renders visibly with its selection panel on-screen.",
          "stepIds": ["character-select"]
        },
        {
          "id": "primary-action-visible",
          "description": "The Confirm Selection action is visible on the character select screen.",
          "controlIds": ["confirm"]
        },
        {
          "id": "progression-possible",
          "description": "A character can be selected and confirmed to advance to the map.",
          "actionIds": ["select-vanguard", "confirm-selection"],
          "stepIds": ["confirm", "map"]
        },
        {
          "id": "no-runtime-blocker",
          "description": "No runtime blocker prevents character selection or confirmation.",
          "stepIds": ["character-select", "confirm"]
        }
      ]
    },
    {
      "sceneId": "MapScene",
      "scene": "MapScene",
      "label": "Map",
      "primaryAction": "Map progression",
      "acceptanceCriteria": [
        {
          "id": "renders-visibly",
          "description": "The map screen renders visibly with the core map content on-screen.",
          "stepIds": ["map"]
        },
        {
          "id": "primary-action-visible",
          "description": "The map screen shows the content needed for the next progression choice.",
          "controlIds": ["node-list"]
        },
        {
          "id": "progression-possible",
          "description": "The core run flow can progress successfully as far as the map milestone.",
          "stepIds": ["map"]
        },
        {
          "id": "no-runtime-blocker",
          "description": "No runtime blocker prevents the map milestone from loading after confirmation.",
          "stepIds": ["map"]
        }
      ]
    }
  ],
