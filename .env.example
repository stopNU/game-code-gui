# Required — Anthropic API key for all agent roles
ANTHROPIC_API_KEY=sk-ant-...

# Optional — FAL.ai API key for image/sprite generation (https://fal.ai/dashboard/keys)
# Without this, assets fall back to placeholder colored rectangles
FAL_KEY=

# Optional — ElevenLabs API key for audio generation
ELEVENLABS_API_KEY=...

# Optional — Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Optional — Turbo remote cache token
TURBO_TOKEN=
TURBO_TEAM=
