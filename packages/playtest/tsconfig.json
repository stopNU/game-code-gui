{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "references": [
    { "path": "../core" },
    { "path": "../tools" },
    { "path": "../game-adapter" }
  ],
  "include": ["src/**/*"],
  "exclude": [
    "src/browser/**",
    "src/harness/**",
    "src/capture/**",
    "src/types/global.d.ts"
  ]
}
