  "scenarios": [
    {
      "id": "build-001",
      "name": "Fresh scaffold typechecks",
      "description": "Verify the scaffolded project compiles without TypeScript errors.",
      "layer": "build",
      "gameSpec": "",
      "inputs": { "projectPath": "" },
      "expectedOutputs": {
        "buildSuccess": true,
        "typecheckPasses": true,
        "bundleSizeKbMax": 3072
      },
      "rubric": {
        "dimensions": [
          { "name": "typecheck", "description": "tsc exits 0", "maxScore": 10, "automated": true },
          { "name": "build", "description": "vite build exits 0", "maxScore": 10, "automated": true },
          { "name": "bundleSize", "description": "bundle <= 3MB", "maxScore": 5, "automated": true }
        ],
        "passingThreshold": 0.8
      },
      "tags": ["smoke", "build"],
      "version": "1.0.0",
      "createdAt": "2026-04-03T00:00:00.000Z"
    },
    {
      "id": "functional-001",
      "name": "Boot to MenuScene",
      "description": "Verify the game boots and reaches MenuScene within 5 seconds.",
      "layer": "functional",
      "gameSpec": "",
      "inputs": {
        "projectPath": "",
        "actions": [
          { "type": "wait", "waitMs": 4000 },
          { "type": "assert", "assertion": { "path": "scene", "operator": "eq", "value": "MenuScene" } }
        ]
      },
      "expectedOutputs": {
        "scenesReachable": ["MenuScene"],
        "fpsMin": 30
      },
      "rubric": {
        "dimensions": [
          { "name": "boot", "description": "BootScene starts", "maxScore": 10, "automated": true },
          { "name": "menu", "description": "MenuScene reached within 5s", "maxScore": 10, "automated": true },
          { "name": "noErrors", "description": "No console errors", "maxScore": 5, "automated": true }
        ],
        "passingThreshold": 0.8
      },
      "tags": ["functional", "boot"],
      "version": "1.0.0",
      "createdAt": "2026-04-03T00:00:00.000Z"
    },
    {
      "id": "functional-002",
      "name": "Start game and enter GameScene",
      "description": "Verify emit('start-game') transitions to GameScene.",
      "layer": "functional",
      "gameSpec": "",
      "inputs": {
        "projectPath": "",
        "actions": [
          { "type": "wait", "waitMs": 4000 },
          { "type": "emit", "target": "start-game" },
          { "type": "wait", "waitMs": 2000 },
          { "type": "assert", "assertion": { "path": "scene", "operator": "eq", "value": "GameScene" } },
          { "type": "assert", "assertion": { "path": "gameState.score", "operator": "exists" } },
          { "type": "assert", "assertion": { "path": "gameState.lives", "operator": "gt", "value": 0 } }
        ]
      },
      "expectedOutputs": {
        "scenesReachable": ["GameScene"],
        "stateAssertions": [
          { "path": "gameState.score", "operator": "exists" },
          { "path": "gameState.lives", "operator": "gt", "value": 0 }
        ]
      },
      "rubric": {
        "dimensions": [
          { "name": "gameScene", "description": "GameScene starts after emit", "maxScore": 10, "automated": true },
          { "name": "stateShape", "description": "score and lives in gameState", "maxScore": 5, "automated": true },
          { "name": "noErrors", "description": "No console errors", "maxScore": 5, "automated": true }
        ],
        "passingThreshold": 0.8
      },
      "tags": ["functional", "gameplay"],
      "version": "1.0.0",
      "createdAt": "2026-04-03T00:00:00.000Z"
    },
    {
      "id": "functional-003",
      "name": "Restart from ResultScene",
