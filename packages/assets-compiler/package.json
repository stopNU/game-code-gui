{
  "name": "@agent-harness/assets-compiler",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "assets-compiler": "./bin/assets-compiler.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-templates.js",
    "start": "node ./bin/assets-compiler.js",
    "dev": "tsx src/cli.ts",
    "preview": "node ./scripts/preview.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "*"
  }
}
